VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Cloudflare Turnstile (public site key — used in the contact form)
# Copy this file to .env for local dev, then restart `npm run dev`.
VITE_TURNSTILE_SITE_KEY=0x4AAAAAADR1WSUlDdPYD7F7

# Cloudflare Pages (dashboard → Settings → Environment variables):
# Build variable: VITE_TURNSTILE_SITE_KEY (same value as above)
# Secrets: turnstile_secret_key, resend_api_key
# Local API testing: copy .dev.vars.example → .dev.vars, then `npm run dev:full`
